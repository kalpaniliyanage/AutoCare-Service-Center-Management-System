<UserControl x:Class="AutoCare.Receptionist"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1100">

    <Grid Background="#121C16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,15,20,5">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="Receptionist Dashboard" FontSize="26" FontWeight="Bold" Foreground="#42D67B"/>
                <TextBlock Text="Vehicle Intake &amp; Customer Registration Suite" FontSize="12" Foreground="#A0AFA6" Margin="0,2,0,0"/>
            </StackPanel>

            <Button Name="btnLogout" Content="Logout" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="80" Height="30" Background="#D9534F" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                    Click="btnLogout_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <TabControl Grid.Row="1" Margin="15,5,15,15" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Header" Value="{Binding Header}"/>
                    <Setter Property="Background" Value="#1A261F"/>
                    <Setter Property="Foreground" Value="#A0AFA6"/>
                    <Setter Property="Padding" Value="18,10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#1E3225"/>
                            <Setter Property="Foreground" Value="#42D67B"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Customer Management">
                <Grid Margin="5,10,5,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A261F" CornerRadius="8" Padding="20" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Customer Workspace" FontSize="18" Foreground="#42D67B" FontWeight="Bold" Margin="0,0,0,20"/>

                            <StackPanel Name="panelEditingIndicator" Visibility="Collapsed" Margin="0,0,0,10">
                                <TextBlock Text="⚡ Currently Editing Profile ID:" Foreground="#FFC107" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Name="lblSelectedCustomerID" Text="0" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Customer Name:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <TextBox Name="txtCustomerName" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="8,0"/>

                            <TextBlock Text="Phone Number:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <TextBox Name="txtPhone" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="8,0"/>

                            <TextBlock Text="Email Address:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <TextBox Name="txtEmail" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" Margin="0,0,0,25" VerticalContentAlignment="Center" Padding="8,0"/>

                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <Button Name="btnSaveCustomer" Content="+ Register" Height="40" Background="#42D67B" Foreground="#121C16" FontWeight="Bold" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand" Click="btnSaveCustomer_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <Button Name="btnUpdateCustomer" Content="✏️ Update" Height="40" Background="#FFC107" Foreground="#121C16" FontWeight="Bold" BorderThickness="0" Margin="5,0,0,0" Cursor="Hand" Click="btnUpdateCustomer_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </UniformGrid>

                            <Button Name="btnClearForm" Content="Clear Fields" Height="30" Background="Transparent" Foreground="#A0AFA6" BorderBrush="#2D4235" BorderThickness="1" Cursor="Hand" Click="btnClearForm_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1A261F" CornerRadius="8" Padding="20" Margin="15,5,5,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Registered Customers Directory" FontSize="16" Foreground="#42D67B" FontWeight="Bold" Margin="0,0,0,5"/>

                            <Grid Grid.Row="1" Margin="0,5,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍 Live Filter Lookup:" Foreground="#A0AFA6" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                                <TextBox Name="txtSearch" Grid.Column="1" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" VerticalContentAlignment="Center" Padding="10,0" TextChanged="txtSearch_TextChanged"/>
                            </Grid>

                            <DataGrid Name="dgvCustomers" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True" 
                                      Background="#121C16" RowBackground="#1A261F" AlternatingRowBackground="#152219" 
                                      Foreground="White" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2D4235"
                                      SelectionChanged="dgvCustomers_SelectionChanged" SelectionMode="Single" Cursor="Hand">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#1E3225"/>
                                        <Setter Property="Foreground" Value="#42D67B"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </DataGrid.Resources>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Vehicle Management">
                <Grid Margin="5,10,5,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A261F" CornerRadius="8" Padding="20" Margin="5">
                        <StackPanel>
                            <TextBlock Text="Vehicle Workspace" FontSize="18" Foreground="#42D67B" FontWeight="Bold" Margin="0,0,0,20"/>
                            <StackPanel Name="panelVehicleEditingIndicator" Visibility="Collapsed" Margin="0,0,0,10">
                                <TextBlock Text="⚡ Currently Editing Vehicle ID:" Foreground="#FFC107" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Name="lblSelectedVehicleID" Text="0" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>

                            <TextBlock Text="Vehicle Reg Number:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <TextBox Name="txtVehicleNo" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="8,0"/>

                            <TextBlock Text="Brand &amp; Model:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <TextBox Name="txtModel" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="8,0"/>

                            <TextBlock Text="Manufactured Year:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <TextBox Name="txtYear" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" Margin="0,0,0,15" VerticalContentAlignment="Center" Padding="8,0"/>

                            <TextBlock Text="Assign Registered Owner:" Foreground="#A0AFA6" Margin="0,5,0,2"/>
                            <ComboBox Name="cmbOwners" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" Margin="0,0,0,25" VerticalContentAlignment="Center" Padding="8,0" DisplayMemberPath="Name" SelectedValuePath="CustomerID">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Background" Value="#1A261F"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>

                            <StackPanel>
                                <Button Name="btnSaveVehicle" Content="+ Attach Vehicle to Owner" Height="44" Background="#42D67B" Foreground="#121C16" FontWeight="Bold" BorderThickness="0" Margin="0,0,0,8" Cursor="Hand" Click="btnSaveVehicle_Click" HorizontalAlignment="Stretch">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                                    <Button Name="btnUpdateVehicle" Content="✏️ Update" Height="40" Background="#FFC107" Foreground="#121C16" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnUpdateVehicle_Click" IsEnabled="True" Margin="0,0,0,6" HorizontalAlignment="Stretch">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Name="btnDeleteVehicle" Content="🗑️ Delete" Height="40" Background="#D9534F" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnDeleteVehicle_Click" IsEnabled="True" HorizontalAlignment="Stretch">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1A261F" CornerRadius="8" Padding="20" Margin="15,5,5,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Active Service Fleet Directory" FontSize="16" Foreground="#42D67B" FontWeight="Bold" Margin="0,0,0,5"/>

                            <Grid Grid.Row="1" Margin="0,5,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍 Plate Search:" Foreground="#A0AFA6" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                                <TextBox Name="txtVehicleSearch" Grid.Column="1" Height="35" Background="#121C16" Foreground="White" BorderBrush="#2D4235" SelectionBrush="#42D67B" VerticalContentAlignment="Center" Padding="10,0" TextChanged="txtVehicleSearch_TextChanged"/>
                            </Grid>

                            <DataGrid Name="dgvVehicles" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgvVehicles_SelectionChanged" SelectionMode="Single"
                                      Background="#121C16" RowBackground="#1A261F" AlternatingRowBackground="#152219" 
                                      Foreground="White" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#2D4235" Cursor="Hand">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="VehicleNo" Binding="{Binding VehicleNo}" Width="2*"/>
                                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="2*"/>
                                    <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="*"/>
                                    <DataGridTextColumn Header="OwnerID" Binding="{Binding OwnerID}" Width="*"/>
                                    <DataGridTextColumn Header="OwnerName" Binding="{Binding OwnerName}" Width="2*"/>
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="2*"/>
                                </DataGrid.Columns>
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#1E3225"/>
                                        <Setter Property="Foreground" Value="#42D67B"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </DataGrid.Resources>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Job Cards &amp; QR Tokens">
                <Grid Margin="20">
                    <TextBlock Text="Job Card Workspace Placeholder" Foreground="#A0AFA6" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>