<Page x:Class="AutoCare.RoleBasedUI.ServiceManager"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Service Manager Dashboard"
      Background="#FFFFFF">

    <Grid Background="#F4F6F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#2C3E50" Grid.Row="0" Padding="15,0">
            <Grid>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="White" Text="🛠️ AUTOCARE - SERVICE MANAGER WORKSPACE" VerticalAlignment="Center"/>
                <TextBlock FontSize="14" Foreground="#BDC3C7" HorizontalAlignment="Right" Text="Passcode: 0002" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Background="#FADBD8" BorderBrush="#E74C3C" BorderThickness="2" CornerRadius="5" Grid.Row="1" Margin="15,10,15,5" Padding="10" Visibility="Collapsed" 
                x:Name="LowStockAlertBorder" 
                MouseDown="LowStockAlertBorder_MouseDown" 
                Cursor="Hand">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="14" FontWeight="Bold" Foreground="#C0392B" Text="⚠️ LOW STOCK ALERT: "/>
                <TextBlock FontSize="14" Foreground="#C0392B" Text="Some spare parts are below the minimum stock level! (Click to filter)" x:Name="TxtAlertMessage"/>
            </StackPanel>
        </Border>

        <TabControl Background="White" Grid.Row="2" Margin="15,10,15,15">
            <TabItem FontSize="14" Header="📦 Inventory Control" Padding="10,5">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="290"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Background="#FBFCFC" Grid.Column="0" Margin="0,0,10,0" Padding="15" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock FontSize="15" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,10" Text="Inventory Control Panel"/>

                                <TextBlock FontSize="11" Foreground="Gray" x:Name="LblSelectedID" Text="Selected ID: None" Margin="0,0,0,5"/>

                                <TextBlock FontSize="12" Margin="0,5,0,2" Text="Item Name:"/>
                                <TextBox Height="28" VerticalContentAlignment="Center" x:Name="TxtItemName"/>

                                <TextBlock FontSize="12" Margin="0,8,0,2" Text="Quantity:"/>
                                <TextBox Height="28" VerticalContentAlignment="Center" x:Name="TxtQuantity"/>

                                <TextBlock FontSize="12" Margin="0,8,0,2" Text="Min Stock Level:"/>
                                <TextBox Height="28" VerticalContentAlignment="Center" x:Name="TxtMinLevel"/>

                                <TextBlock FontSize="12" Margin="0,8,0,2" Text="Unit Price (Rs.):"/>
                                <TextBox Height="28" VerticalContentAlignment="Center" x:Name="TxtPrice"/>

                                <Button Background="#27AE60" Click="BtnAddItem_Click" Content="➕ Add Item" FontWeight="Bold" Foreground="White" Height="32" Margin="0,15,0,5" x:Name="BtnAddItem"/>

                                <UniformGrid Columns="2" Margin="0,2,0,5">
                                    <Button Background="#E67E22" Click="BtnUpdateItem_Click" Content="📝 Update" FontWeight="Bold" Foreground="White" Height="32" Margin="0,0,2,0" x:Name="BtnUpdate"/>
                                    <Button Background="#C0392B" Click="BtnDeleteItem_Click" Content="🗑️ Delete" FontWeight="Bold" Foreground="White" Height="32" Margin="2,0,0,0" x:Name="BtnDelete"/>
                                </UniformGrid>

                                <Button Background="#7F8C8D" Click="BtnClearForm_Click" Content="🔄 Clear / Reset" Foreground="White" Height="28" Margin="0,2,0,5" x:Name="BtnClear"/>

                                <Separator Margin="0,15"/>

                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8" Text="Data Import / Export (CSV)"/>
                                <Button Background="#2980B9" Click="BtnImport_Click" Content="📥 Import from CSV" FontWeight="Bold" Foreground="White" Height="32" Margin="0,0,0,6" x:Name="BtnImport"/>
                                <Button Background="#8E44AD" Click="BtnExport_Click" Content="📤 Export to CSV" FontWeight="Bold" Foreground="White" Height="32" Margin="0,0,0,0" x:Name="BtnExport"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <DataGrid AlternatingRowBackground="#F2F4F4" AutoGenerateColumns="False" BorderBrush="#BDC3C7" CanUserAddRows="False" Grid.Column="1" x:Name="DgvInventory" 
                  MouseDoubleClick="DgvInventory_MouseDoubleClick" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding ItemID}" Header="Item ID" Width="60"/>
                            <DataGridTextColumn Binding="{Binding ItemName}" Header="Item Name" Width="*"/>
                            <DataGridTextColumn Binding="{Binding Quantity}" Header="Qty Available" Width="100"/>
                            <DataGridTextColumn Binding="{Binding MinStockLevel}" Header="Min Level" Width="90"/>
                            <DataGridTextColumn Binding="{Binding UnitPrice}" Header="Unit Price (Rs)" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

            <TabItem FontSize="14" Header="🔧 Job Allocation &amp; Tracking" Padding="10,5">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="290"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 1. වම් පැත්ත: Job Allocation Control Panel -->
                    <Border Background="#FBFCFC" Grid.Column="0" Margin="0,0,10,0" Padding="15" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5">
                        <StackPanel>
                            <TextBlock FontSize="15" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10" Text="Job Assignment Panel"/>

                            <!-- තෝරාගත් Job එකේ ID එක පෙන්වන්න -->
                            <TextBlock FontSize="11" Foreground="Gray" x:Name="LblSelectedJobID" Text="Selected Job ID: None" Margin="0,0,0,10"/>

                            <!-- වාහන අංකය (Read Only) -->
                            <TextBlock FontSize="12" Margin="0,5,0,2" Text="Vehicle Number:"/>
                            <TextBox Height="28" VerticalContentAlignment="Center" x:Name="TxtJobVehicle" IsReadOnly="True" Background="#F4F6F6"/>

                            <!-- ලෙඩේ විස්තරය (Read Only) -->
                            <TextBlock FontSize="12" Margin="0,8,0,2" Text="Issue Description:"/>
                            <TextBox Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" x:Name="TxtJobIssue" IsReadOnly="True" Background="#F4F6F6"/>

                            <Separator Margin="0,15"/>

                            <!-- Mechanic කෙනෙක්ව තෝරන කොටස -->
                            <TextBlock FontSize="12" FontWeight="Bold" Margin="0,5,0,2" Text="Assign Mechanic:"/>
                            <ComboBox Height="30" VerticalContentAlignment="Center" x:Name="CmbMechanics">
                                <ComboBoxItem Content="Kamal Silva"/>
                                <ComboBoxItem Content="Nimal Perera"/>
                                <ComboBoxItem Content="Sunil Shantha"/>
                                <ComboBoxItem Content="Ruwan Fernando"/>
                            </ComboBox>

                            <!-- Job Status එක තෝරන කොටස -->
                            <TextBlock FontSize="12" FontWeight="Bold" Margin="0,10,0,2" Text="Job Status:"/>
                            <ComboBox Height="30" VerticalContentAlignment="Center" x:Name="CmbStatus">
                                <ComboBoxItem Content="Pending"/>
                                <ComboBoxItem Content="In Progress"/>
                                <ComboBoxItem Content="Completed"/>
                            </ComboBox>

                            <!-- Assign / Update Button -->
                            <Button Background="#2980B9" Click="BtnAssignJob_Click" Content="💼 Assign &amp; Update Status" FontWeight="Bold" Foreground="White" Height="35" Margin="0,20,0,5" x:Name="BtnAssignJob"/>

                            <!-- Reset Button -->
                            <Button Background="#7F8C8D" Click="BtnClearJobForm_Click" Content="🔄 Clear Selection" Foreground="White" Height="28" Margin="0,5,0,0" x:Name="BtnClearJobForm"/>
                        </StackPanel>
                    </Border>

                    <!-- 2. දකුණු පැත්ත: Job Cards පෙන්වන DataGrid එක -->
                    <DataGrid AlternatingRowBackground="#F2F4F4" AutoGenerateColumns="False" BorderBrush="#BDC3C7" CanUserAddRows="False" Grid.Column="1" x:Name="DgvJobs" 
                  MouseDoubleClick="DgvJobs_MouseDoubleClick" IsReadOnly="True" SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding JobID}" Header="Job ID" Width="60"/>
                            <DataGridTextColumn Binding="{Binding VehicleNumber}" Header="Vehicle No" Width="100"/>
                            <DataGridTextColumn Binding="{Binding CustomerName}" Header="Customer Name" Width="120"/>
                            <DataGridTextColumn Binding="{Binding IssueDescription}" Header="Issue Description" Width="*"/>
                            <DataGridTextColumn Binding="{Binding AssignedMechanic}" Header="Assigned Mechanic" Width="130"/>

                            <!-- Status එක වෙනස් පාට වලින් පෙන්වන්න පසුව පුළුවන්, දැනට Text එකක් විදිහට දාමු -->
                            <DataGridTextColumn Binding="{Binding Status}" Header="Status" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>